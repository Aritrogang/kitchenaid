# Copy to .env (gitignored). The core loop + the gate run with NONE of these set —
# only LLM *generation* needs a key. See docs/AI_SETUP.md.

# Enable the live Creative Chef (text generation). Get one at console.anthropic.com.
ANTHROPIC_API_KEY=sk-ant-...

# Optional model overrides (defaults shown). Generation uses the cheap model on purpose.
# ANTHROPIC_GEN_MODEL=claude-haiku-4-5-20251001     # high-volume recipe generation
# ANTHROPIC_MODEL=claude-sonnet-4-6                  # corpus reranking
# ANTHROPIC_REASON_MODEL=claude-opus-4-8             # deep reasoning (future Concierge)

# Surface live-call errors (auth/parse/model) instead of silently falling back to corpus.
# KITCHENAID_DEBUG=1

# Persistence. UNSET => taste memory is stored as JSON files under state/ (the dev default).
# SET => the Profile Keeper uses Postgres instead. Run migrations once after setting it:
#   DATABASE_URL=... python -m kitchenaid.store migrate
# Needs the db extra:  pip install -e ".[db]"    See docs/PERSISTENCE.md.
# DATABASE_URL=postgresql://user:password@localhost:5432/kitchenaid

# Opt IN to LLM corpus reranking on every recommend (costs money per turn; off by default so
# a plain "what's for dinner" stays free and taste-aware). Generation is separate + unaffected.
# KITCHENAID_LLM_RERANK=1

# Spend guardrail (defaults are conservative — raise only if you mean to). A paid call is
# refused BEFORE it fires if any cap would be crossed. See kitchenaid/budget.py.
# KITCHENAID_MAX_CALLS_PER_RUN=25
# KITCHENAID_MAX_CALLS_PER_DAY=200
# KITCHENAID_MAX_USD_PER_DAY=1.00

# Per-USER daily caps (opt-in; unset = off). The caps above protect the whole account; these
# stop one user from consuming everyone's budget. Set them once you serve multiple users.
# KITCHENAID_MAX_CALLS_PER_USER_PER_DAY=50
# KITCHENAID_MAX_USD_PER_USER_PER_DAY=0.25

# Phase 4 only — taste-memory embeddings. NOT used yet. Anthropic has no native embeddings
# endpoint; plan a separate provider (Voyage AI is Anthropic's recommended partner).
# VOYAGE_API_KEY=...
