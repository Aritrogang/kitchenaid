# Keep the Vercel deploy lean: only the API (kitchenaid + migrations), the web client, and the
# function entrypoint ship. Everything below is dev/CI/native and not needed at runtime.
ios/
tests/
examples/
docs/
.github/
state/
eval/
.env
*.md
docker-compose.yml
Dockerfile
render.yaml
# Exclude pyproject so Vercel's Python builder uses pip + requirements.txt (not uv on the
# whole project, whose optional extras conflict across the 3.9–3.12 support range).
pyproject.toml
