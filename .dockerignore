# Keep the build context (and image) small and secret-free.
.git
.github
.venv
venv
__pycache__
*.pyc
.pytest_cache
.mypy_cache

# Never ship secrets or local state.
.env
state/
eval/spend_ledger.jsonl

# Not part of the API image (frontends, native app, docs, tests, tooling).
web/
ios/
docs/
tests/
examples/
.claude/
*.md
